# ==========================================
# Dokploy & Environment Configuration
# ==========================================
ENVIRONMENT=production

# ==========================================
# Database & Cache Configuration
# ==========================================
DB_HOST=echo-postgres
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=echo_db
DATABASE_URL=postgresql://user:password@echo-postgres:5432/echo_db?sslmode=disable

REDIS_ADDR=echo-redis:6379
REDIS_PASSWORD=
REDIS_URL=redis://echo-redis:6379

STATE_BACKEND=redis

# ==========================================
# Application Ports & Internal Routing
# ==========================================
BACKEND_PORT=8080
AGENT_PORT=3001
FRONTEND_PORT=3000
HOSTNAME=0.0.0.0

# Client Browser Public API URL (Exposed to client browser)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# SSR & Server-to-Server Internal Backend URL (Docker internal network)
BACKEND_URL=http://echo-backend:8080
INTERNAL_BACKEND_URL=http://echo-backend:8080
AGENT_HTTP_URL=http://echo-agent:3001

# Public API Documentation URLs (Scalar)
BACKEND_API_DOCS_URL=https://api.yourdomain.com/api/docs
AGENT_API_DOCS_URL=https://agent.yourdomain.com/docs

# CORS Allowed Origins (Comma-separated)
ALLOW_ORIGINS=https://yourdomain.com,http://localhost:3000

# ==========================================
# Security & Authentication Secrets
# ==========================================
JWT_SECRET=change-this-to-a-secure-random-jwt-secret
INTERNAL_AUTH_TOKEN=change-this-to-a-secure-internal-token

# ==========================================
# LLM Provider API Keys & Settings
# ==========================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODELS=gpt-4o,gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODELS=claude-3-5-sonnet-latest,claude-3-haiku

DEFAULT_MODEL=gpt-4o

# ==========================================
# Observability Configuration
# ==========================================
ENABLE_OTEL=false
OTEL_COLLECTOR_ADDR=echo-otel-collector:4317

