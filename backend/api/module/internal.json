{
    "basePath": "/",
    "definitions": {
        "internal_handler.PruneRequest": {
            "type": "object",
            "properties": {
                "provider_config": {
                    "type": "object",
                    "additionalProperties": true,
                    "example": {
                        "type": "openai",
                        "base_url": "https://api.openai.com/v1",
                        "model": "gpt-4o"
                    }
                }
            }
        },
        "internal_handler.episodicRecallRequest": {
            "type": "object",
            "required": [
                "session_id"
            ],
            "properties": {
                "limit": {
                    "type": "integer",
                    "example": 50
                },
                "offset": {
                    "type": "integer",
                    "example": 0
                },
                "session_id": {
                    "type": "string",
                    "example": "sess_abc123"
                }
            }
        },
        "internal_handler.episodicStoreRequest": {
            "type": "object",
            "required": [
                "session_id",
                "content"
            ],
            "properties": {
                "content": {
                    "example": {
                        "text": "User asked about pricing plans"
                    }
                },
                "metadata": {},
                "session_id": {
                    "type": "string",
                    "example": "sess_abc123"
                }
            }
        },
        "internal_handler.proceduralGetRequest": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string",
                    "example": "mem_pr_e5f6g7h8"
                },
                "name": {
                    "type": "string",
                    "example": "deploy-to-ecs"
                }
            }
        },
        "internal_handler.proceduralStoreRequest": {
            "type": "object",
            "required": [
                "id",
                "name",
                "content"
            ],
            "properties": {
                "content": {
                    "type": "string",
                    "example": "1. Build Docker image\n2. Push to ECR\n3. Update ECS service"
                },
                "id": {
                    "type": "string",
                    "example": "mem_pr_e5f6g7h8"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": true
                },
                "name": {
                    "type": "string",
                    "example": "deploy-to-ecs"
                }
            }
        },
        "internal_handler.semanticSearchRequest": {
            "type": "object",
            "required": [
                "query"
            ],
            "properties": {
                "embedding": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "example": [
                        0.012,
                        0.034,
                        -0.056
                    ]
                },
                "limit": {
                    "type": "integer",
                    "example": 10
                },
                "query": {
                    "type": "string",
                    "example": "What is Echo agent platform?"
                },
                "threshold": {
                    "type": "number",
                    "example": 0.75
                }
            }
        },
        "internal_handler.semanticStoreRequest": {
            "type": "object",
            "required": [
                "id",
                "content"
            ],
            "properties": {
                "content": {
                    "type": "string",
                    "example": "Echo is an AI agent platform for autonomous task execution"
                },
                "embedding": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "example": [
                        0.012,
                        0.034,
                        -0.056,
                        0.078
                    ]
                },
                "id": {
                    "type": "string",
                    "example": "mem_sm_a1b2c3d4"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": true
                }
            }
        }
    },
