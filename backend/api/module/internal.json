                                    "example": "mem_ep_a1b2c3d4"
                                },
                                "status": {
                                    "type": "string",
                                    "example": "stored"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Validation error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "boolean",
                                    "example": false
                                },
                                "error": {
                                    "type": "string",
                                    "example": "validation_error"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "session_id and content are required"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "boolean",
                                    "example": false
                                },
                                "error": {
                                    "type": "string",
                                    "example": "internal_error"
