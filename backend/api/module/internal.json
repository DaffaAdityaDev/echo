        "/api/v1/internal/sessions/{id}/prune": {
            "post": {
                "tags": [
                    "Internal"
                ],
                "summary": "Prune and consolidate session",
                "description": "Trigger LLM-driven memory consolidation for a session",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Session ID",
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "example": "sess_abc123"
                    },
                    {
                        "description": "Provider config payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handler.PruneRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Consolidation status",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "status": {
                                    "type": "string",
                                    "example": "success"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Session pruned and consolidated successfully"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request body",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "Invalid request body"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Consolidation failed",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string",
                                    "example": "Consolidation failed"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ]
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Bearer token authorization header (Format: Bearer \u003cJWT\u003e).",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    },
