    "paths": {
        "/api/v1/internal/memory/episodic/recall": {
            "post": {
                "tags": [
                    "Internal"
                ],
                "summary": "Recall episodic memory",
                "description": "Retrieve episodic conversation context from Redis",
                "parameters": [
                    {
                        "description": "Episodic recall payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handler.episodicRecallRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Episodic entries",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "session_id": {
                                    "type": "string",
                                    "example": "sess_abc123"
                                },
                                "entries": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "content": {
                                                "type": "string",
                                                "example": "{\"text\":\"User asked about pricing\"}"
                                            },
                                            "timestamp": {
                                                "type": "string",
                                                "example": "2026-01-15T10:30:00Z"
                                            }
                                        }
                                    }
                                },
                                "total": {
                                    "type": "integer",
                                    "example": 25
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Validation error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "boolean",
                                    "example": false
                                },
                                "error": {
                                    "type": "string",
                                    "example": "validation_error"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "session_id is required"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "boolean",
                                    "example": false
                                },
                                "error": {
                                    "type": "string",
                                    "example": "internal_error"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Failed to recall episodic memory"
                                }
                            }
                        }
                    }
                },
                "security": null,
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ]
            }
        },
        "/api/v1/internal/memory/episodic/store": {
            "post": {
                "tags": [
                    "Internal"
                ],
                "summary": "Store episodic memory",
                "description": "Save episodic conversation context into Redis",
                "parameters": [
                    {
                        "description": "Episodic store payload",
                        "name": "request",
