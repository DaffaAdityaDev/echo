                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "boolean",
                                    "example": false
                                },
                                "error": {
                                    "type": "string",
                                    "example": "internal_error"
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Failed to get procedural memory"
                                }
                            }
                        }
                    }
                },
                "security": null,
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ]
            }
        },
