{
    "basePath": "/",
    "definitions": {
        "echo-backend_internal_models.ApiKey": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string",
                    "example": "2026-01-15T10:30:00Z"
                },
                "id": {
                    "type": "string",
                    "example": "key_a1b2c3d4e5f6"
                },
                "name": {
                    "type": "string",
                    "example": "Production API Key"
                },
                "prefix": {
                    "type": "string",
                    "example": "sk_a1b2c3d4"
                },
                "scopes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "read",
                        "write",
                        "admin"
                    ]
                },
                "status": {
                    "type": "string",
                    "example": "active"
                },
                "user_id": {
                    "type": "string",
                    "example": "1"
                }
            }
        },
        "echo-backend_internal_models.Session": {
            "type": "object",
            "properties": {
                "context_summary": {
                    "type": "string",
                    "example": "User is building a REST API for a todo app using Express and Prisma"
                },
                "created_at": {
                    "type": "string",
                    "example": "2026-01-15T10:30:00Z"
                },
                "id": {
                    "type": "string",
                    "example": "sess_abc123"
                },
                "message_count": {
                    "type": "integer",
                    "example": 12
                },
                "status": {
                    "type": "string",
                    "example": "active"
                },
                "title": {
                    "type": "string",
                    "example": "Build a REST API with Express"
                },
                "token_count": {
                    "type": "integer",
                    "example": 3421
                },
                "updated_at": {
                    "type": "string",
                    "example": "2026-01-15T11:45:00Z"
                },
                "user_id": {
                    "type": "integer",
                    "example": 1
                }
            }
        },
        "echo-backend_internal_models.User": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string",
                    "example": "2026-01-15T10:30:00Z"
                },
                "email": {
                    "type": "string",
                    "example": "jane@example.com"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "name": {
                    "type": "string",
                    "example": "Jane Doe"
                },
                "role": {
                    "type": "string",
                    "example": "user"
                },
                "updated_at": {
                    "type": "string",
                    "example": "2026-01-15T10:30:00Z"
                }
            }
        },
        "echo-backend_internal_models.UserPreferences": {
            "type": "object",
            "properties": {
                "default_features": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "web-browsing",
                        "code-interpreter"
                    ]
                },
                "default_mode": {
                    "type": "string",
                    "example": "agent"
                },
                "default_model": {
                    "type": "string",
                    "example": "gpt-4o"
                },
                "default_skills": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "python",
                        "research"
                    ]
                },
                "user_id": {
                    "type": "integer",
                    "example": 1
                }
            }
        }
    },
    "host": "localhost:8080",
    "info": {
