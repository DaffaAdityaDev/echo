{
  "openapi": "3.0.3",
  "info": {
    "title": "Echo Agent Platform API",
    "version": "1.0.0",
    "description": "Autonomous AI Agent Platform runtime, mission execution engine, skills, features, and model proxy API.\n\nTriggers autonomous agent execution loops using configurable LLM providers (OpenAI, Anthropic, LM Studio, OpenCode Go) with full tool-calling, memory, and streaming support."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current Environment Server"
    }
  ],
  "security": [
    {
      "InternalTokenAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "InternalTokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Internal-Token",
        "description": "Internal service-to-service authentication token"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "User JWT Bearer token for authenticated API access"
      }
    },
    "schemas": {
      "ModelInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "gpt-4o"
          },
          "name": {
            "type": "string",
            "example": "GPT-4o"
          }
        }
      }
    }
  },
  "paths": {
    "/api/models": {
      "get": {
        "summary": "List agent provider models",
        "description": "Fetch supported LLM provider model catalog",
        "security": [
          {
            "InternalTokenAuth": []
          },
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Model catalog",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "models": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ModelInfo"
                      }
                    }
                  }
                },
                "example": {
                  "models": [
                    {
                      "id": "gpt-4o",
                      "name": "GPT-4o"
                    },
                    {
                      "id": "gpt-4o-mini",
                      "name": "GPT-4o Mini"
                    },
                    {
                      "id": "claude-sonnet-4-20250514",
                      "name": "Claude Sonnet 4"
                    },
                    {
                      "id": "deepseek-v4-flash",
                      "name": "DeepSeek V4 Flash"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}