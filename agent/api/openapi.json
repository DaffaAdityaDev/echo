    "/api/internal/sessions/summarize": {
      "post": {
        "summary": "Summarize chat session history",
        "description": "Uses the configured LLM provider to produce a condensed session summary from the provided message history.",
        "security": [
          {"InternalTokenAuth": []},
          {"BearerAuth": []}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SummarizeRequest"
              },
              "example": {
                "session_id": "sess_abc123",
                "messages": [
                  {"role": "user", "content": "Build a REST API for a todo app with Express and Prisma"},
                  {"role": "assistant", "content": "I'll help you build that. Let me start by scaffolding the project."},
                  {"role": "tool_call", "content": "file_system: mkdir /app/todo-api"},
                  {"role": "tool_result", "content": "Directory created successfully"},
                  {"role": "assistant", "content": "I've created the project directory. Let me now set up the dependencies."}
                ],
                "provider_config": {
                  "type": "openai",
                  "base_url": "https://api.openai.com/v1",
                  "api_key": "sk-proj-xxxxxxxxxxxxxx",
                  "model": "gpt-4o"
                },
                "max_summary_tokens": 500
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session summary result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummarizeResponse"
                },
                "example": {
                  "summary": "The user, a software engineer, asked the AI agent to build a REST API for a todo application using Express.js and Prisma ORM. The agent scaffolded the project, configured the database schema with User and Todo models, implemented JWT-based authentication, and created CRUD endpoints for todo items with proper error handling.",
                  "token_count": 142,
                  "messages_summarized": 5
                }
              }
            }
          },
          "400": {
            "description": "Invalid input - missing messages or provider_config",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": "error",
                  "error_type": "BAD_REQUEST",
                  "message": "Missing or invalid 'messages' array"
                }
              }
            }
          },
          "500": {
            "description": "Summarization error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": "error",
                  "error_type": "INTERNAL_SERVER_ERROR",
                  "message": "Summarization failed",
                  "details": "Provider returned 429 Too Many Requests"
                }
              }
            }
          }
        }
      }
    }
  }
}