{
  "name": "echo-agent",
  "version": "1.0.0",
  "description": "Node.js Agent for Echo",
  "main": "dist/index.js",
  "scripts": {
    "docs": "node api/merge.mjs",
    "build": "npm run docs && bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "node dist/index.js",
    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@hono/node-server": "^2.0.1",
    "@langchain/anthropic": "^1.3.29",
    "@langchain/community": "^1.1.10",
    "@langchain/core": "^1.1.45",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/openai": "^1.2.4",
    "@langfuse/otel": "^5.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.0.1",
    "cheerio": "^1.0.0",
    "chromadb": "^1.10.0",
    "deepagents": "^1.10.0",
    "dotenv": "^17.2.3",
    "hono": "^4.12.18",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.4.0",
    "@scalar/hono-api-reference": "^0.5.171",
